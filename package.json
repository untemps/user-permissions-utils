{
	"name": "@untemps/user-permissions-utils",
	"version": "1.1.35",
	"description": "Collection of utility functions to manage user permissions",
	"repository": "git@github.com:untemps/user-permissions-utils.git",
	"keywords": [
		"utils",
		"permissions",
		"javascript"
	],
	"author": "Vincent Le Badezet <v.lebadezet@untemps.net>",
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"main": "dist/index.js",
	"module": "dist/index.es.js",
	"exports": {
		".": {
			"import": "./dist/index.es.js",
			"require": "./dist/index.js",
			"default": "./dist/index.es.js"
		}
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@semantic-release/changelog": "^6.0.1",
		"@semantic-release/git": "^10.0.1",
		"@vitest/coverage-v8": "^4.1.6",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.3",
		"semantic-release": "^25.0.3",
		"vite": "^8.0.12",
		"vitest": "^4.1.6"
	},
	"release": {
		"branches": [
			"main"
		],
		"plugins": [
			[
				"@semantic-release/commit-analyzer",
				{
					"releaseRules": [
						{
							"type": "chore",
							"release": "patch"
						}
					]
				}
			],
			"@semantic-release/release-notes-generator",
			"@semantic-release/changelog",
			"@semantic-release/npm",
			"@semantic-release/git"
		]
	},
	"scripts": {
		"test": "vitest",
		"test:ci": "vitest run --coverage",
		"build": "vite build",
		"prettier": "prettier \"*/**/*.js\" --ignore-path ./.prettierignore --write",
		"prepare": "husky"
	}
}
